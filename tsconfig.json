{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",           /* The modern standard */
    "moduleResolution": "NodeNext", /* Resolves imports the modern Node way */
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,                 /* The most important flag */
    "noImplicitAny": true,          /* Prevents lazy typing */
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}